# =============================================================================
# Bwaincell Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For production, uncomment the production-URL lines and comment out dev ones.
# =============================================================================

# -----------------------------------------------------------------------------
# Discord Bot Configuration (REQUIRED)
# -----------------------------------------------------------------------------
BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_for_testing

# -----------------------------------------------------------------------------
# User Mapping — Email to Discord ID (REQUIRED for API authentication)
# -----------------------------------------------------------------------------
USER1_EMAIL=your@email.com
USER1_DISCORD_ID=your_discord_user_id_here
USER2_EMAIL=partner@email.com
USER2_DISCORD_ID=partner_discord_user_id_here

# -----------------------------------------------------------------------------
# Google OAuth Configuration (REQUIRED for API authentication)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
ALLOWED_GOOGLE_EMAILS=user1@gmail.com,user2@gmail.com

# -----------------------------------------------------------------------------
# NextAuth Configuration (REQUIRED for frontend authentication)
# -----------------------------------------------------------------------------
# NextAuth URL for OAuth callbacks
# Development:
NEXTAUTH_URL=http://localhost:3010
# Production:
# NEXTAUTH_URL=https://bwaincell.sunny-stack.com

NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Optional: Override frontend API base URL. Defaults to same-origin (/api).
# NEXT_PUBLIC_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# JWT Configuration (REQUIRED for API authentication)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=generate_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
# Port for Express API (health endpoint and REST API)
# Docker exposes this port — don't change unless you update docker-compose.yml
API_PORT=3000
PORT=3000

# -----------------------------------------------------------------------------
# Supabase Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get values from `npx supabase status` (local) or your self-hosted instance (Pi)
# Local dev:
SUPABASE_URL=http://127.0.0.1:54321
# Production (Pi Deployment):
# SUPABASE_URL=http://127.0.0.1:54321  # when bot runs on the same Pi as Supabase
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase database password (loaded by supabase/config.toml via env())
# Local dev: postgres (default)
SUPABASE_DB_PASSWORD=postgres
# Production:
# SUPABASE_DB_PASSWORD=generate_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Timezone for reminders and scheduled tasks
# IMPORTANT: Set this BEFORE using DateTime.now() or Date operations
# Examples: America/Los_Angeles, America/Chicago, America/New_York, UTC
TIMEZONE=America/Los_Angeles

# Discord channel ID for announcements
DEFAULT_REMINDER_CHANNEL=your_channel_id_for_reminders

# Milliseconds before Discord command responses are auto-deleted
DELETE_COMMAND_AFTER=300000

# -----------------------------------------------------------------------------
# Deployment Configuration (Raspberry Pi)
# -----------------------------------------------------------------------------
# Environment mode
NODE_ENV=development
# NODE_ENV=production

# Deployment platform identifier (optional)
DEPLOYMENT_MODE=pi

# Database backups are managed by the self-hosted Supabase instance on Pi
# Configure backup strategy via Supabase Studio or pg_dump cron

# -----------------------------------------------------------------------------
# GitHub Integration (for /issues Discord command)
# -----------------------------------------------------------------------------
# GitHub Fine-Grained Personal Access Token with 'issues' permissions
# Scoped for {{GITHUB_REPO_NAME}} Repo
# Generate at: https://github.com/settings/tokens/new
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# GitHub repository details for issue creation
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=Bwaincell

# -----------------------------------------------------------------------------
# Gemini AI Configuration (for /random date command)
# -----------------------------------------------------------------------------
# Google Gemini API Key
# Get yours at: https://ai.google.dev/
# Used to generate AI-powered date suggestions with location awareness
GEMINI_API_KEY=your_gemini_api_key_here

# Location for date suggestions (ZIP code format)
# Example: 90210 (Beverly Hills, CA)
LOCATION_ZIP_CODE=ZIP_CODE_HERE

# =============================================================================
# GitHub Actions Secrets (for Auto-Deployment)
# =============================================================================
# These secrets are NOT stored in .env — they go in GitHub repository settings.
# Go to: Repository Settings → Secrets and variables → Actions → New repository secret
#
# -----------------------------------------------------------------------------
# Raspberry Pi Deployment Secrets (bot + Supabase)
# -----------------------------------------------------------------------------
# Required for .github/workflows/deploy.yml → deploy job
#
# PI_HOST=192.168.1.100 (REQUIRED)
#   - Public IP address of your Raspberry Pi (NOT hostname)
#   - GitHub Actions cannot resolve local hostnames like "sunny-pi"
#   - Find with: ssh sunny-pi && curl -s ifconfig.me
#
# PI_USERNAME=pi (REQUIRED)
#   - SSH username for the Raspberry Pi
#
# PI_SSH_KEY=<paste entire private key> (REQUIRED)
#   - Your private SSH key for authentication
#   - Get it: cat ~/.ssh/id_rsa (or id_ed25519)
#   - Copy ENTIRE key including -----BEGIN/END----- lines
#
# PI_SSH_PASSPHRASE=your_passphrase (OPTIONAL)
#   - Only needed if your SSH key has a passphrase
#
# PI_SSH_PORT=22 (OPTIONAL)
#   - Only add if you use a custom SSH port
#
# -----------------------------------------------------------------------------
# GHCR (GitHub Container Registry) Pull Secret
# -----------------------------------------------------------------------------
# Required for .github/workflows/deploy.yml → deploy-bot job
# The bot image is built on GitHub Actions and pushed to GHCR. The Pi pulls
# this prebuilt image instead of building locally (saves ~15 min per deploy).
#
# PI_GHCR_TOKEN=ghp_xxx (REQUIRED)
#   - GitHub Personal Access Token (classic) with read:packages scope
#   - Generate at: https://github.com/settings/tokens/new
#     → select scope: read:packages  (do NOT grant more)
#   - Used by the Pi (via the workflow) to authenticate with ghcr.io
#
# One-time Pi setup (after creating the token):
#   # On the Pi, cache credentials so manual `docker pull` works too:
#   echo 'YOUR_PAT_HERE' | docker login ghcr.io -u strawhatluka --password-stdin
#
# Image location:
#   ghcr.io/strawhatluka/bwaincell-backend:latest (and :<git-sha> per deploy)
#
# -----------------------------------------------------------------------------
# Vercel Deployment Secrets (frontend deploy-on-release)
# -----------------------------------------------------------------------------
# Required for .github/workflows/deploy.yml → deploy-vercel job
#
# VERCEL_TOKEN=xxx (REQUIRED)
#   - Personal access token from https://vercel.com/account/tokens
#
# VERCEL_ORG_ID=team_xxx (REQUIRED)
#   - Team/org ID (starts with "team_") or personal user ID
#   - Found in: frontend/.vercel/project.json (field: orgId) after `vercel link`
#
# VERCEL_PROJECT_ID=prj_xxx (REQUIRED)
#   - Vercel project ID (starts with "prj_")
#   - Found in: frontend/.vercel/project.json (field: projectId) after `vercel link`
#
# One-time setup (local):
#   cd frontend
#   vercel login
#   vercel link
#   cat .vercel/project.json
#   # Copy orgId  → VERCEL_ORG_ID GitHub secret
#   # Copy projectId → VERCEL_PROJECT_ID GitHub secret
#
# Then in the Vercel dashboard (Settings → Environment Variables), configure:
#   - NEXTAUTH_URL=https://bwaincell.sunny-stack.com
#   - NEXTAUTH_SECRET=(match your root .env for session continuity)
#   - GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, NEXT_PUBLIC_GOOGLE_CLIENT_ID
#   - SUPABASE_URL=http://<pi-public-ip>:54321
#   - SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY
#   - GUILD_ID, USER1_EMAIL, USER1_DISCORD_ID, USER2_EMAIL, USER2_DISCORD_ID
#
# =============================================================================

# =============================================================================
# Deployment Notes
# =============================================================================
#
# Local Development:
#   - Copy this file to .env in project root
#   - Set NODE_ENV=development
#   - Start Supabase: npm run supabase:start
#   - Get keys from `npm run supabase:status`
#   - Run dev servers: npm run dev
#
# Raspberry Pi Deployment:
#   1. SSH into Pi
#   2. Create .env file: nano ~/bwaincell/.env
#   3. Copy values from your local .env, update for production
#   4. Set NODE_ENV=production and DEPLOYMENT_MODE=pi
#   5. Update SUPABASE_URL to http://127.0.0.1:54321 (bot + Supabase on same Pi)
#   6. Set a strong SUPABASE_DB_PASSWORD
#   7. Set permissions: chmod 600 .env
#   8. Start Supabase: npm run supabase:start
#   9. Deploy bot: docker compose up -d
#
# GitHub Actions Setup (auto-deployment):
#   1. Go to GitHub repository → Settings → Secrets and variables → Actions
#   2. Add each Pi and Vercel secret listed above
#   3. Publish a release to trigger deployment
#   4. Monitor: https://github.com/<your-repo>/actions
#
# Security:
#   - NEVER commit .env to git (already in .gitignore)
#   - NEVER share BOT_TOKEN, JWT_SECRET, NEXTAUTH_SECRET, or SSH keys
#   - Set file permissions on Pi: chmod 600 .env
#   - Rotate JWT_SECRET and SUPABASE_DB_PASSWORD periodically
#   - Use strong passwords for Google OAuth
#
# Troubleshooting:
#   - Deployment fails? Check GitHub Actions logs
#   - Bot won't start? Check: docker logs bwaincell-backend
#   - Can't SSH? Verify PI_HOST and PI_SSH_KEY are correct
#   - Health check fails? Verify PORT=3000 and curl http://localhost:3000/health
#   - DB connection fails? Check: npm run supabase:status
#   - Supabase won't start? Check: docker ps (Supabase runs its own containers)
#
# =============================================================================
